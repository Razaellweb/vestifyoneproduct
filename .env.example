# Vestify One Backend Environment Variables

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SUPABASE (Database)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AUTH
BETTER_AUTH_SECRET=change-me
AUTH_ACCESS_TOKEN_TTL=900
AUTH_REFRESH_TOKEN_TTL=2592000

# SECURITY
ENCRYPTION_KEY=replace-with-strong-secret-32+chars

# PAYMENTS (Paystack)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_CALLBACK_URL=http://localhost:3000/api/v1/webhooks/payments

# EMAIL (Resend)
RESEND_API_KEY=re_test_xxx
RESEND_FROM=Vestify One <no-reply@vestify.one>

# KYC (QoreID)
QOREID_CLIENT_ID=your-qoreid-client-id
QOREID_CLIENT_SECRET=your-qoreid-client-secret

# MONITORING/ANALYTICS
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# MESSAGING PROVIDERS (optional)
SMS_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_API_KEY=
